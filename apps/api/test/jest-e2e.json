{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@portfolio/shared$": "<rootDir>/../../../packages/shared/src/index.ts"
  },
  "maxWorkers": 1,
  "runInBand": true
}
